      "WebFetch(domain:arkivanov.github.io)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:proandroiddev.com)",
      "WebFetch(domain:jasondl.ee)",
      "Bash(jq:*)",
